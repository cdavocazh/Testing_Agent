# ─── Testing Agent Configuration ─────────────────────────────────────

# LLM Provider for the Testing Agent itself
# The testing agent uses its own LLM to reason about test results.
# Options: minimax, deepseek, openai
LLM_PROVIDER=minimax
MINIMAX_API_KEY=your-minimax-api-key-here
# DEEPSEEK_API_KEY=your-deepseek-key-here
# OPENAI_API_KEY=your-openai-key-here

# FRED API key (needed by Financial Agent tools under test)
FRED_API_KEY=your-fred-api-key-here

# Path to the Financial Agent project root
FINANCIAL_AGENT_ROOT=/Users/kriszhang/Github/Financial_Agent

# Test settings
TEST_TIMEOUT=30          # seconds per tool call
TEST_VERBOSE=true        # print detailed output during test runs
